FoamFile
{
    format      ascii;
    class       volVectorField;
    location    "0";
    object      U;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 -1 0 0 0 0];
internalField   uniform (0 0 0);
boundaryField
{
    inlet
    {
        type            fixedProfile;
        profile         table (
    (0.00000 (0.13988 0 0))
    (0.05000 (0.76412 0 0))
    (0.10000 (0.92344 0 0))
    (0.15000 (1.03162 0 0))
    (0.20000 (1.11598 0 0))
    (0.25000 (1.18614 0 0))
    (0.30000 (1.24672 0 0))
    (0.35000 (1.30035 0 0))
    (0.40000 (1.34867 0 0))
);
        direction       (0 0 1);
        origin          0;
    }
    outlet    { type inletOutlet; inletValue uniform (0 0 0); value uniform (0 0 0); }
    ground    { type noSlip; }
    buildings { type noSlip; }
    top       { type slip; }
    sides     { type symmetry; }
}

