FoamFile
{
    format      ascii;
    class       volScalarField;
    location    "0";
    object      k;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 2 -2 0 0 0 0];
internalField   uniform 0.019571;
boundaryField
{
    inlet     { type fixedValue; value uniform 0.019571; }
    outlet    { type inletOutlet; inletValue uniform 0.019571; value uniform 0.019571; }
    ground    { type kqRWallFunction; value uniform 0.019571; }
    buildings { type kqRWallFunction; value uniform 0.019571; }
    top       { type slip; }
    sides     { type symmetry; }
}

